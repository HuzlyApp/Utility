# AI Analysis
XAI_API_KEY=your_xai_api_key_here
# Prefer XAI_MODEL. Options: grok-4.5 (default), grok-4.3, grok-4, grok-4-fast
XAI_MODEL=grok-4.5
# Reasoning depth for grok-4.5: low | medium | high
XAI_REASONING_EFFORT=high
# Keep at 0 for more consistent match scores across re-runs
XAI_TEMPERATURE=0

# xAI API Settings (reasoning models need longer timeouts)
XAI_TIMEOUT_MS=180000
XAI_MAX_RETRIES=1

# Claude / Anthropic (optional; required only when selecting Claude in the UI)
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_TIMEOUT_MS=180000
CLAUDE_MAX_TOKENS=8192
CLAUDE_TEMPERATURE=0

# Neon Database
# Get connection string from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Neon MCP Server
# Get API key from: https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=your_neon_api_key_here

# Application Settings
RECENT_EXPERIENCE_MONTHS=24
MAX_UPLOAD_MB=10

# Neon Auth (Managed Better Auth)
# Base URL of your hosted Neon Auth server (Neon Console > Auth)
NEON_AUTH_BASE_URL=https://your-project.neonauth.region.aws.neon.tech/neondb/auth
# 32+ character secret for signing the session-data cache cookie
# Generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=change_me_at_least_32_characters_long

# Initial admin bootstrap (scripts/bootstrap-admin.mjs)
ADMIN_EMAIL=admin@utility.com
ADMIN_INITIAL_PASSWORD=admin2026!

# Image / OCR limits
MAX_IMAGE_DIMENSION=10000
OCR_MIN_CONFIDENCE=60
# Vision model used only as a controlled fallback when OCR/extraction fail
XAI_VISION_MODEL=grok-4.5
