# AI Analysis
XAI_API_KEY=your_xai_api_key_here
# XAI_MODEL options: grok-4-fast (default), grok-4, grok-3
XAI_MODEL=grok-4-fast

# xAI API Settings
XAI_TIMEOUT_MS=60000
XAI_MAX_RETRIES=1

# Neon Database
# Get connection string from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Neon MCP Server
# Get API key from: https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=your_neon_api_key_here

# Application Settings
RECENT_EXPERIENCE_MONTHS=24
MAX_UPLOAD_MB=10
